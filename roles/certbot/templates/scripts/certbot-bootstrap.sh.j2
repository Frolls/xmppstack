#!/usr/bin/env sh
set -eu

CERTBOT_EMAIL="{{ xmpp_stack_certbot_email }}"
CERTBOT_DOMAINS="{{ xmpp_stack_certbot_domains | join(',') }}"
NGINX_STOPPED=0

restore_nginx() {
  if [ "$NGINX_STOPPED" -eq 1 ]; then
    systemctl start nginx.service || true
  fi
}

mkdir -p {{ xmpp_stack_letsencrypt_dir }}

systemctl start xmpp-network-network.service postgres.service || true

DOMAINS_ARGS=""
OLD_IFS="$IFS"
IFS=','
for domain in $CERTBOT_DOMAINS; do
  DOMAINS_ARGS="$DOMAINS_ARGS -d $domain"
done
IFS="$OLD_IFS"

{% if xmpp_stack_enable_nginx %}
trap restore_nginx EXIT INT TERM
systemctl stop nginx.service || true
NGINX_STOPPED=1
{% endif %}
podman run --rm \
  --network host \
  -v {{ xmpp_stack_letsencrypt_dir }}:/etc/letsencrypt:Z \
  docker.io/certbot/certbot:latest \
  certonly \
  --standalone \
  --non-interactive \
  --agree-tos \
  --email "$CERTBOT_EMAIL" \
  $DOMAINS_ARGS
{{ xmpp_stack_app_root }}/scripts/sync-ejabberd-certs.sh
{% if xmpp_stack_enable_nginx %}
systemctl start nginx.service || true
NGINX_STOPPED=0
trap - EXIT INT TERM
systemctl restart ejabberd.service coturn.service
systemctl restart nginx.service || true
{% else %}
systemctl restart ejabberd.service coturn.service
{% endif %}
