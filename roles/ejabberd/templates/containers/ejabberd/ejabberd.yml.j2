hosts:
  - "{{ xmpp_stack_domain }}"

loglevel: {{ xmpp_stack_log_level }}
hide_sensitive_log_data: true
log_rotate_count: 10
log_rotate_size: 10485760

default_db: sql
sql_type: pgsql
sql_server: postgres
sql_database: {{ xmpp_stack_postgres_db }}
sql_username: {{ xmpp_stack_postgres_user }}
sql_password: "{{ xmpp_stack_postgres_password }}"
sql_pool_size: 8
update_sql_schema: true

auth_password_format: scram
s2s_use_starttls: required

disable_sasl_mechanisms:
  - "digest-md5"
  - "X-OAUTH2"

certfiles:
  - "/etc/letsencrypt/live/{{ xmpp_stack_domain }}/fullchain.pem"
  - "/etc/letsencrypt/live/{{ xmpp_stack_domain }}/privkey.pem"

define_macro:
  'TLS_CIPHERS': "HIGH:!aNULL:!eNULL:!3DES:@STRENGTH"
  'TLS_OPTIONS':
    - "no_sslv3"
    - "no_tlsv1"
    - "no_tlsv1_1"
    - "cipher_server_preference"
    - "no_compression"

c2s_ciphers: 'TLS_CIPHERS'
s2s_ciphers: 'TLS_CIPHERS'
c2s_protocol_options: 'TLS_OPTIONS'
s2s_protocol_options: 'TLS_OPTIONS'

shaper:
  normal: {{ xmpp_stack_c2s_shaper_rate }}
  fast: {{ xmpp_stack_s2s_shaper_rate }}

shaper_rules:
  max_user_sessions:
    - {{ xmpp_stack_max_user_sessions }}: all
  max_user_offline_messages:
    - {{ xmpp_stack_max_user_offline_messages }}: all
  c2s_shaper:
    - none: admin
    - normal: all
  s2s_shaper: fast

acl:
  admin:
    user:
      - "{{ xmpp_stack_admin_jid }}"
  local:
    user_regexp: ""
  loopback:
    ip:
      - "127.0.0.0/8"
      - "::1/128"
      - "::FFFF:127.0.0.1/128"

access_rules:
  c2s:
    - allow: local
    - deny: all
  announce:
    - allow: admin
    - deny: all
  configure:
    - allow: admin
    - deny: all
  muc:
    - allow: local
    - deny: all
  muc_create:
    - allow: local
  pubsub_createnode:
    - allow: local
    - deny: all
  register:
    - deny: all
  http_upload:
    - allow: local
  trusted_network:
    - allow: loopback
    - deny: all

api_permissions:
  "console commands":
    from:
      - ejabberd_ctl
    who: all
    what: "*"
  "admin access":
    who:
      - access:
          - allow:
              - acl: loopback
              - acl: admin
        oauth:
          - scope: "ejabberd:admin"
            access:
              - allow:
                  - acl: loopback
                  - acl: admin
    what:
      - "*"
      - "!stop"
      - "!restart"
  "public commands":
    who:
      - ip: "127.0.0.1/32"
      - ip: "::1/128"
    what:
      - "status"
      - "connected_users_number"

listen:
  -
    port: {{ xmpp_stack_c2s_port }}
    ip: "::"
    module: ejabberd_c2s
    max_stanza_size: 262144
    shaper: c2s_shaper
    access: c2s
    starttls_required: true
    protocol_options: 'TLS_OPTIONS'
{% if xmpp_stack_enable_federation %}
  -
    port: {{ xmpp_stack_s2s_port }}
    ip: "::"
    module: ejabberd_s2s_in
    max_stanza_size: 524288
    shaper: s2s_shaper
{% endif %}
  -
    port: {{ xmpp_stack_ejabberd_http_port }}
    ip: "::"
    module: ejabberd_http
    request_handlers:
      "/upload": mod_http_upload
      "/ws": ejabberd_http_ws

modules:
  mod_adhoc: {}
  mod_admin_extra: {}
  mod_announce:
    access: announce
  mod_avatar: {}
  mod_blocking: {}
  mod_caps: {}
  mod_carboncopy: {}
  mod_client_state: {}
  mod_configure: {}
  mod_disco: {}
  mod_fail2ban: {}
  mod_http_upload:
    host: "upload.@HOST@"
    access: http_upload
    max_size: 52428800
    docroot: "/var/lib/ejabberd/upload"
    put_url: "https://{{ xmpp_stack_upload_host }}/upload"
    get_url: "https://{{ xmpp_stack_upload_host }}/upload"
    thumbnail: false
    jid_in_url: sha1
  mod_http_upload_quota:
    max_days: 7
{% if xmpp_stack_enable_invites %}
  mod_invites:
    landing_page: {{ xmpp_stack_invites_landing_page }}
    max_invites: {{ xmpp_stack_invites_max }}
    token_expire_seconds: {{ xmpp_stack_invites_token_expire_seconds }}
{% endif %}
  mod_last: {}
  mod_mam:
    db_type: sql
    default: always
    assume_mam_usage: true
  mod_muc:
    host: "conference.@HOST@"
    access:
      - allow: local
    access_create: muc_create
    access_persistent: muc_create
    default_room_options:
      allow_subscription: true
      mam: true
      persistent: true
  mod_muc_admin: {}
  mod_offline:
    access_max_user_messages: max_user_offline_messages
  mod_ping: {}
  mod_pres_counter:
    count: 5
    interval: 60
  mod_privacy: {}
  mod_pubsub:
    access_createnode: pubsub_createnode
    plugins:
      - "flat"
      - "pep"
    force_node_config:
      "eu.siacs.conversations.axolotl.*":
        access_model: open
      "storage:bookmarks":
        access_model: whitelist
  mod_push: {}
  mod_push_keepalive: {}
  mod_roster:
    versioning: true
  mod_s2s_bidi: {}
{% if xmpp_stack_enable_federation %}
  mod_s2s_dialback: {}
{% endif %}
  mod_scram_upgrade:
    offered_upgrades:
      - sha256
      - sha512
  mod_stream_mgmt:
    resend_on_timeout: if_offline
  mod_vcard:
    search: false
  mod_stun_disco:
    credentials_lifetime: 12h
    services:
      -
        host: "{{ xmpp_stack_domain }}"
        port: {{ xmpp_stack_turn_port }}
        type: stun
        transport: udp
        restricted: false
      -
        host: "{{ xmpp_stack_domain }}"
        port: {{ xmpp_stack_turn_port }}
        type: turn
        transport: udp
        restricted: true
      -
        host: "{{ xmpp_stack_domain }}"
        port: {{ xmpp_stack_turn_port }}
        type: stun
        transport: tcp
        restricted: false
      -
        host: "{{ xmpp_stack_domain }}"
        port: {{ xmpp_stack_turn_port }}
        type: turn
        transport: tcp
        restricted: true
      -
        host: "{{ xmpp_stack_domain }}"
        port: {{ xmpp_stack_turn_tls_port }}
        type: turns
        transport: tcp
        restricted: true

language: "ru"
